{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/leap-of-legends/leap-of-legends-sdk/mod.schema.json",
  "title": "Leap of Legends mod.json",
  "description": "Schema for Leap of Legends JSON game-mode mods (mod API 1.1). Add \"$schema\": \"./mod.schema.json\" (or the raw GitHub URL) to your mod.json for editor autocomplete and validation.",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$",
      "description": "Unique reverse-domain mod id, e.g. com.yourname.yourmod"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name (English fallback)"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "api_version": {
      "type": "string",
      "default": "1.0",
      "enum": [
        "1.0",
        "1.1"
      ],
      "description": "Mod API level. Use 1.1 for movement, when-conditions, on_interval/on_death, announce and the other 1.1 features."
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "thumbnail": {
      "type": "string",
      "default": "thumbnail.png"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steam_workshop_id": {
      "type": "integer",
      "description": "Set automatically by the in-game Workshop upload"
    },
    "players": {
      "type": "object",
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "max": {
          "type": "integer",
          "maximum": 8,
          "default": 6
        }
      }
    },
    "ai": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "default": 3
        },
        "chase_range": {
          "type": "number",
          "default": 14
        },
        "stomp_range": {
          "type": "number",
          "default": 4
        },
        "bias_right": {
          "type": "boolean",
          "default": false
        },
        "custom_behavior": {
          "type": "string",
          "enum": [
            "",
            "default",
            "lab_aware",
            "guard_position",
            "seek_objective",
            "aggressive",
            "passive",
            "patrol",
            "seek_gold",
            "capture_the_flag"
          ]
        },
        "lab_seek_probability": {
          "type": "number"
        },
        "button_press_probability": {
          "type": "number"
        },
        "guard_x": {
          "type": "number"
        },
        "guard_y": {
          "type": "number"
        },
        "guard_radius": {
          "type": "number",
          "default": 8
        },
        "objective_seek_probability": {
          "type": "number",
          "default": 0.6
        },
        "aggression": {
          "type": "number",
          "default": 1
        },
        "patrol_waypoints": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Flat [x1,y1,x2,y2,...] waypoint list"
        }
      }
    },
    "teams": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "count": {
          "type": "integer",
          "minimum": 2,
          "maximum": 4,
          "default": 2
        },
        "friendly_fire": {
          "type": "boolean",
          "default": false
        },
        "auto_balance": {
          "type": "boolean",
          "default": true,
          "description": "Accepted for compatibility; balancing is always on"
        },
        "definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              "name": {
                "type": "string"
              },
              "color": {
                "$ref": "#/definitions/color"
              },
              "base_x": {
                "type": "integer"
              },
              "base_y": {
                "type": "integer"
              }
            }
          }
        }
      }
    },
    "map": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 12,
          "maximum": 64,
          "default": 26
        },
        "height": {
          "type": "integer",
          "minimum": 10,
          "maximum": 32,
          "default": 16
        },
        "open_right": {
          "type": "boolean",
          "default": false
        },
        "open_left": {
          "type": "boolean",
          "default": false,
          "description": "Reserved — only honored by 3D modes today"
        },
        "open_top": {
          "type": "boolean",
          "default": false
        },
        "water_height": {
          "type": "integer",
          "default": 2
        },
        "jumpers_enabled": {
          "type": "boolean",
          "default": true
        },
        "jumper_min_spacing": {
          "type": "integer",
          "default": 15
        },
        "jumper_min_air_above": {
          "type": "integer",
          "default": 10
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "min_x": {
                "type": "integer"
              },
              "min_y": {
                "type": "integer"
              },
              "max_x": {
                "type": "integer"
              },
              "max_y": {
                "type": "integer"
              },
              "cell_type": {
                "type": "string",
                "enum": [
                  "air",
                  "rock",
                  "water",
                  "ice",
                  "sand",
                  "dirt",
                  "gravel",
                  "grass"
                ],
                "default": "air",
                "description": "air/water/ice are exact; all solid types become solid ground re-themed by position"
              }
            }
          }
        },
        "layout": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[.#~ISDVGisdvg]{8,64}$"
          },
          "minItems": 6,
          "maxItems": 32,
          "description": "Fixed hand-authored map (api 1.1). One string per ROW, top row first; all rows the same length (8-64 chars, 6-32 rows). Replaces WFC generation, the water_height flood, and region cell painting (regions stay as named areas for mechanics). Legend: '.' air, '#' rock, '~' water, 'I' ice, 'S' sand, 'D' dirt, 'V' gravel, 'G' grass. Author it in-game: Mods screen -> Map Editor."
        }
      }
    },
    "timer": {
      "type": "number",
      "minimum": 0,
      "default": 360,
      "description": "Match seconds; 0 = no timer"
    },
    "win_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "timer",
              "score",
              "team_score",
              "all_dead",
              "all_humans_dead",
              "captures",
              "zone_hold",
              "checkpoint_race",
              "state",
              "last_standing"
            ]
          },
          "target": {
            "type": "integer"
          },
          "hold_time": {
            "type": "number"
          },
          "key": {
            "type": "string",
            "description": "state: mod state key to test (api 1.1)"
          },
          "op": {
            "$ref": "#/definitions/compareOp"
          },
          "value": {
            "type": "number",
            "description": "state: comparison value (api 1.1)"
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "kills",
            "team_kills",
            "resource",
            "captures",
            "distance",
            "zone_time",
            "checkpoints"
          ],
          "default": "kills"
        },
        "label": {
          "type": "string",
          "default": "Kills"
        },
        "resource": {
          "type": "string"
        },
        "points_per_kill": {
          "type": "integer",
          "default": 1
        },
        "points_per_event": {
          "type": "integer",
          "default": 1
        },
        "streaks": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "announce_at": {
              "type": "integer",
              "default": 3
            }
          }
        }
      }
    },
    "spawn": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "maximin",
            "random",
            "team_zones",
            "team_base",
            "behind_leader"
          ],
          "default": "maximin"
        },
        "respawn_delay": {
          "type": "number",
          "default": 2,
          "description": "Reserved — engine currently uses a fixed 0.5s"
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "team": {
                "type": "integer"
              },
              "x_min_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "x_max_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "camera": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "follow",
            "fullmap",
            "scrolling"
          ],
          "default": "follow",
          "description": "All 2D modes run the single tuned follow camera; fullmap/scrolling are legacy aliases of follow"
        },
        "padding": {
          "type": "number",
          "description": "Legacy no-op"
        },
        "scroll_speed": {
          "type": "number",
          "description": "Legacy no-op"
        }
      }
    },
    "movement": {
      "type": "object",
      "description": "Mod-wide movement multipliers for every player (api 1.1). Clamped to 0.25-4.0; compose multiplicatively with effects.",
      "properties": {
        "move_speed": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 4,
          "default": 1
        },
        "jump": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 4,
          "default": 1
        },
        "gravity": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 4,
          "default": 1
        }
      }
    },
    "hud": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "timer",
              "team_scores",
              "leaderboard",
              "streak_popup",
              "resource",
              "player_count",
              "message",
              "flag_status",
              "button_cooldown",
              "progress_bar",
              "kill_feed",
              "custom_counter",
              "announcement"
            ]
          },
          "anchor": {
            "type": "string",
            "enum": [
              "top_left",
              "top_center",
              "top_right",
              "center",
              "bottom_left",
              "bottom_center",
              "bottom_right",
              "top_bar"
            ],
            "default": "top_center",
            "description": "Screen anchor. Widgets sharing an anchor stack into a column (declaration order = top to bottom) instead of overlapping; offsets add on top."
          },
          "font_size": {
            "type": "integer"
          },
          "color": {
            "$ref": "#/definitions/color"
          },
          "offset_x": {
            "type": "integer"
          },
          "offset_y": {
            "type": "integer"
          },
          "flash_below": {
            "type": "number"
          },
          "flash_color": {
            "$ref": "#/definitions/color"
          },
          "show_target": {
            "type": "boolean"
          },
          "target": {
            "type": "integer"
          },
          "max_entries": {
            "type": "integer",
            "default": 6
          },
          "min_streak": {
            "type": "integer",
            "default": 3
          },
          "duration": {
            "type": "number"
          },
          "resource": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "progress_key": {
            "type": "string"
          },
          "bar_width": {
            "type": "integer",
            "default": 200
          },
          "bar_height": {
            "type": "integer",
            "default": 20
          },
          "fill_color": {
            "$ref": "#/definitions/color"
          },
          "bg_color": {
            "$ref": "#/definitions/color"
          },
          "feed_entries": {
            "type": "integer",
            "default": 5
          },
          "feed_duration": {
            "type": "number",
            "default": 4
          },
          "counter_key": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "default": "{value}"
          }
        }
      }
    },
    "post_match": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "default": "MATCH OVER"
        },
        "show_mvp": {
          "type": "boolean",
          "default": true
        },
        "show_team_result": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type_id"
        ],
        "properties": {
          "type_id": {
            "type": "integer",
            "minimum": 64,
            "maximum": 255
          },
          "name": {
            "type": "string"
          },
          "behavior": {
            "type": "string",
            "enum": [
              "buff",
              "debuff",
              "trigger",
              "periodic"
            ],
            "default": "buff"
          },
          "color": {
            "$ref": "#/definitions/color"
          },
          "apply_as": {
            "type": "string",
            "enum": [
              "none",
              "speed_boost",
              "jump_boost",
              "speed_slow",
              "invincibility",
              "damage",
              "instant_kill",
              "teleport",
              "gravity"
            ],
            "default": "none"
          },
          "magnitude": {
            "type": "number",
            "default": 1
          },
          "duration": {
            "type": "number",
            "default": 5
          }
        }
      }
    },
    "mechanics": {
      "type": "array",
      "description": "One entry per mechanic type; a duplicate type is ignored.",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "collectible",
              "flag",
              "zone_button",
              "effect_zone",
              "zone_control",
              "portal",
              "hazard_zone",
              "checkpoint"
            ]
          },
          "resource": {
            "type": "string"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "maxItems": 7
          },
          "initial_count": {
            "type": "integer",
            "default": 30
          },
          "max_on_map": {
            "type": "integer",
            "default": 80
          },
          "respawn_interval": {
            "type": "number",
            "default": 8
          },
          "respawn_batch": {
            "type": "integer",
            "default": 3
          },
          "pickup_radius": {
            "type": "number",
            "default": 1.2
          },
          "scatter_on_death": {
            "type": "boolean",
            "default": true
          },
          "scatter_velocity": {
            "type": "number",
            "default": 5
          },
          "max_scatter_coins": {
            "type": "integer",
            "default": 20
          },
          "auto_return_time": {
            "type": "number",
            "default": 30
          },
          "flag_pickup_radius": {
            "type": "number",
            "default": 1.5
          },
          "capture_radius": {
            "type": "number",
            "default": 2
          },
          "id": {
            "type": "string"
          },
          "safe_zone": {
            "type": "string"
          },
          "cooldown": {
            "type": "number",
            "default": 45
          },
          "kill_outside": {
            "type": "boolean",
            "default": true
          },
          "credit_to_presser": {
            "type": "boolean",
            "default": true
          },
          "button_radius": {
            "type": "number",
            "default": 1
          },
          "button_x": {
            "type": "number"
          },
          "button_y": {
            "type": "number"
          },
          "positions": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "effect_id": {
            "type": "integer"
          },
          "effect_duration": {
            "type": "number",
            "default": 5
          },
          "effect_magnitude": {
            "type": "number",
            "default": 1
          },
          "zone_radius": {
            "type": "number",
            "default": 1.5
          },
          "persistent": {
            "type": "boolean",
            "default": true
          },
          "one_shot": {
            "type": "boolean",
            "default": false
          },
          "zone_respawn_time": {
            "type": "number"
          },
          "zone_id": {
            "type": "string"
          },
          "capture_time": {
            "type": "number",
            "default": 10
          },
          "points_per_capture": {
            "type": "integer",
            "default": 1
          },
          "reset_on_contest": {
            "type": "boolean",
            "default": true
          },
          "progress_key_prefix": {
            "type": "string",
            "default": "zone_progress"
          },
          "portal_pairs": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Flat [ax,ay,bx,by,...] — length multiple of 4"
          },
          "portal_radius": {
            "type": "number",
            "default": 1
          },
          "portal_cooldown": {
            "type": "number",
            "default": 2
          },
          "hazard_zones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hazard_type": {
            "type": "string",
            "enum": [
              "instant_kill",
              "periodic_damage",
              "slow"
            ],
            "default": "periodic_damage"
          },
          "hazard_effect_id": {
            "type": "integer",
            "default": 5
          },
          "hazard_magnitude": {
            "type": "number",
            "default": 1
          },
          "checkpoint_positions": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "checkpoint_radius": {
            "type": "number",
            "default": 2
          },
          "ordered": {
            "type": "boolean",
            "default": true
          },
          "laps": {
            "type": "integer",
            "default": 0
          }
        }
      }
    },
    "mod_state": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "int",
              "float",
              "bool"
            ],
            "default": "int"
          },
          "default_value": {
            "type": "number",
            "default": 0
          }
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_name"
        ],
        "properties": {
          "event_name": {
            "type": "string",
            "enum": [
              "on_match_start",
              "on_match_end",
              "on_player_joined",
              "on_player_left",
              "on_kill",
              "on_death",
              "on_interval",
              "on_custom_event"
            ]
          },
          "custom_event": {
            "type": "string"
          },
          "interval": {
            "type": "number",
            "minimum": 1,
            "description": "on_interval: seconds between firings (api 1.1)"
          },
          "first_delay": {
            "type": "number",
            "description": "on_interval: delay before first firing; defaults to interval (api 1.1)"
          },
          "when": {
            "type": "array",
            "description": "All conditions must hold for the trigger to run (api 1.1)",
            "items": {
              "type": "object",
              "required": [
                "key"
              ],
              "properties": {
                "key": {
                  "type": "string"
                },
                "op": {
                  "$ref": "#/definitions/compareOp"
                },
                "value": {
                  "type": "number"
                }
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "action"
              ],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": [
                    "set_mod_int",
                    "set_mod_float",
                    "set_mod_bool",
                    "add_mod_int",
                    "add_mod_float",
                    "add_score",
                    "broadcast_event",
                    "apply_effect",
                    "kill_player",
                    "teleport_player",
                    "set_timer",
                    "add_timer",
                    "end_match",
                    "announce"
                  ]
                },
                "key": {
                  "type": "string",
                  "description": "Mod state key, or region id for teleport_player"
                },
                "int_value": {
                  "type": "integer"
                },
                "float_value": {
                  "type": "number"
                },
                "bool_value": {
                  "type": "boolean"
                },
                "event_broadcast": {
                  "type": "string"
                },
                "effect_id": {
                  "type": "integer"
                },
                "effect_duration": {
                  "type": "number",
                  "default": 5
                },
                "effect_magnitude": {
                  "type": "number",
                  "default": 1
                },
                "target": {
                  "type": "string",
                  "enum": [
                    "player",
                    "killer",
                    "victim",
                    "all",
                    "team"
                  ],
                  "default": "player"
                },
                "text": {
                  "type": "string",
                  "description": "announce: text shown by the announcement HUD widget (api 1.1)"
                },
                "duration": {
                  "type": "number",
                  "default": 3,
                  "description": "announce: display seconds (api 1.1)"
                },
                "x": {
                  "type": "number",
                  "description": "teleport_player destination x when no region key (api 1.1)"
                },
                "y": {
                  "type": "number",
                  "description": "teleport_player destination y when no region key (api 1.1)"
                }
              }
            }
          }
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "description": "Custom match background image (api 1.1). Local + cosmetic on every peer; desktop only. A file named background.png next to mod.json is picked up automatically even without this block.",
      "properties": {
        "image": {
          "type": "string",
          "description": "Image file relative to the mod folder (.png/.jpg). Empty = auto-detect background.png."
        },
        "brightness": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 1.0,
          "default": 1.0,
          "description": "Tint multiplier. Stock backgrounds render at 0.44 so gameplay reads on top; mod images default to full brightness."
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "description": "Custom match music + voice nudge overrides (api 1.1). Files load locally from the mod folder (.ogg recommended, .wav/.mp3 also supported); desktop only. Child accounts always keep the curated stock audio.",
      "properties": {
        "music": {
          "type": "string",
          "description": "Music file relative to the mod folder. Empty = auto-detect music.ogg/.wav/.mp3. Numbered variants (music_1.ogg, ...) form a shuffled playlist."
        },
        "music_volume": {
          "type": "number",
          "minimum": 0.05,
          "maximum": 1.0,
          "default": 1.0,
          "description": "Extra volume scale on top of the player's music setting."
        },
        "voice_dir": {
          "type": "string",
          "default": "voice",
          "description": "Folder scanned for voice/SFX overrides named after the built-in clip keys. Single-kill pool (random per kill): Voice_Yeah, Voice_Smasher, Voice_OhYeah, Voice_Ninja, Voice_Hmm, Voice_Crusher. Match events: Voice_FirstBlood (first kill, everyone hears). Multi-kills (killer only): Voice_DoubleKill, Voice_TripleKill, Voice_QuadKill. Streak tiers (killer only): Voice_LikeABoss, Voice_Legendary, Voice_Dominating. Kill impact SFX: Crush (gore on), Poof (gore off / child-safe). Numbered variants (Key_1, Key_2, ...) play at random per nudge."
        }
      }
    }
  },
  "patternProperties": {
    "^name_(arabic|bulgarian|schinese|tchinese|czech|danish|dutch|english|finnish|french|german|greek|hungarian|indonesian|italian|japanese|koreana|norwegian|polish|portuguese|brazilian|romanian|russian|spanish|latam|swedish|thai|turkish|ukrainian|vietnamese)$": {
